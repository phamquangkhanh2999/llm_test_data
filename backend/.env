# CẤU HÌNH MÔI TRƯỜNG PYTHON BACKEND
# Khóa kết nối API thật (Hệ thống hỗ trợ cả Gemini API và OpenAI API)
# Nếu sử dụng Gemini API, hãy điền GEMINI_API_KEY dưới đây.
GEMINI_API_KEY=
# Nếu sử dụng OpenAI API, hãy điền OPENAI_API_KEY dưới đây.
OPENAI_API_KEY=

# Đường dẫn kết nối cơ sở dữ liệu SQLite cục bộ (Tự sinh tệp tin testforge.db trong thư mục backend)
DATABASE_URL=sqlite:///./testforge.db
